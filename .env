# -----------------------------
# Raspberry Pi Passive-Income Appliance Config
# -----------------------------

# Portainer admin password
PORTAINER_PASSWORD=ChangeThisPassword

# Honeygain credentials
HONEYGAIN_EMAIL=you@example.com
HONEYGAIN_PASSWORD=yourpassword
HONEYGAIN_DEVICE=PI1

# Pawns credentials
PAWNS_EMAIL=you@example.com
PAWNS_PASSWORD=yourpassword
PAWNS_DEVICE=PI1

# EarnApp token (auto-filled by installer)
EARNAPP_TOKEN=REPLACE_ME

# Watchtower update schedule (cron)
WATCHTOWER_SCHEDULE="0 */6 * * *"
